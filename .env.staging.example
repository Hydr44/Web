# Template env per ambiente STAGING (branch `staging` → staging.rescuemanager.eu).
# Copia in `.env.staging` (gitignored) per uso locale, OPPURE setta queste come
# Vercel Environment Variables sulla scope "Preview" + filtro branch "staging".

# ============ Supabase ============
# TODO: quando avrai Supabase Pro + branching, qui usi le credenziali del branch
# staging. Per ora puoi puntare a un secondo progetto Supabase dedicato a test.
NEXT_PUBLIC_SUPABASE_URL=https://<STAGING-PROJECT>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<staging_anon_key>
SUPABASE_SERVICE_ROLE_KEY=<staging_service_role_key>  # SERVER-ONLY, mai in client

# ============ Pairing JWT ============
# Usa un secret DIVERSO da prod per evitare cross-contamination.
PAIRING_JWT_SECRET=<openssl rand -base64 32 — diverso da quello prod>

# ============ Staff auth ============
STAFF_JWT_SECRET=<openssl rand -base64 32 — diverso da prod>

# ============ Analytics (di solito si disabilitano in staging) ============
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_HOTJAR_ID=

# ============ Integrations ============
NEXT_PUBLIC_CHATWOOT_WEBSITE_TOKEN=

# ============ Marker ambiente ============
# Utile per banner "STAGING" nel frontend e per Sentry environment tag.
NEXT_PUBLIC_APP_ENV=staging
