# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Google Analytics (opzionale - per analytics)
# Ottieni il tuo ID da: https://analytics.google.com
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Meta Pixel (opzionale - per marketing)
# Ottieni il tuo ID da: https://business.facebook.com/events_manager
NEXT_PUBLIC_META_PIXEL_ID=

# Hotjar (opzionale - per analytics)
# Ottieni il tuo ID da: https://www.hotjar.com
NEXT_PUBLIC_HOTJAR_ID=

# Altri servizi
NEXT_PUBLIC_CHATWOOT_WEBSITE_TOKEN=

# Pairing JWT (desktop → mobile via QR)
# Genera con: openssl rand -base64 32
# Usato da /api/auth/pair/{generate,exchange}. NON committare, settare in Vercel.
PAIRING_JWT_SECRET=
